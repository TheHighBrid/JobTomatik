# Database
# Safe local default for Android + Termux + Ubuntu PRoot.
DATABASE_URL=sqlite:///./jobtomatik.db
# Optional PostgreSQL deployment example. Start PostgreSQL and create the database/user before enabling it.
# DATABASE_URL=postgresql://jobtomatik:jobtomatik_pass@localhost:5432/jobtomatik

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-long-random-string-in-production
# Optional separate key for encrypted applicant answer policies. Keep stable after policies are created.
# When empty, SECRET_KEY is used.
ANSWER_VAULT_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Comma-separated credentialed browser origins. Add only origins that host your JobTomatik UI.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://localhost,http://localhost,capacitor://localhost

# AI
# Default is free local cover-letter templates. Set AI_PROVIDER=anthropic only after adding billing/credits.
AI_PROVIDER=template
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Email
# If SENDGRID_API_KEY is empty, email is logged/mocked.
SENDGRID_API_KEY=
FROM_EMAIL=noreply@jobtomatik.com

# Job search
# Keep false for real use. Set true only for local UI demos when boards block scraping.
DEV_MOCK_JOBS=false

# Persistent application browser
# JobTomatik keeps a dedicated Chromium profile for LinkedIn and employer ATS sessions.
# On Android + XFCE, keep HEADLESS=false, log in once in the opened Chromium window,
# and reuse the same profile on every later run. Do not point this at a profile that is
# simultaneously open in another Chromium process.
APPLICATION_BROWSER_PROFILE_DIR=browser_profiles/jobtomatik-operator
APPLICATION_BROWSER_HEADLESS=false
# Optional path to system Chromium/Chrome. Empty uses Playwright's installed Chromium.
APPLICATION_BROWSER_EXECUTABLE=
# Zero creates the secure retained-browser handoff immediately when automatic target
# resolution cannot continue. Set a positive value only when an operator is already
# watching the visible browser and wants a brief window to click Apply before handoff.
APPLICATION_TARGET_HUMAN_WAIT_SECONDS=0

# Application submit safety
# Real submit stays blocked unless this is explicitly true and the active adapter gate permits it.
ALLOW_REAL_APPLICATION_SUBMIT=false
# Separate platform pilot gates. Keep false until that platform's controlled pilot is explicitly authorized.
# The global flag, matching platform flag, and a one-time exact approval are all required.
GREENHOUSE_SUPERVISED_PILOT_ENABLED=false
LEVER_SUPERVISED_PILOT_ENABLED=false
SUPERVISED_APPROVAL_TTL_MINUTES=20
SUPERVISED_APPROVAL_MAX_TTL_MINUTES=60

# Canonical Greenhouse pilot evidence
# The Phase A baseline is read-only and artifact-backed. Runtime ingestion writes only Phase B records.
GREENHOUSE_PILOT_BASELINE_PATH=evidence/greenhouse-phase-a-baseline.csv
GREENHOUSE_PILOT_LEDGER_PATH=evidence/greenhouse-pilot-ledger.jsonl
GREENHOUSE_PILOT_READINESS_JSON_PATH=evidence/greenhouse-pilot-readiness.json
GREENHOUSE_PILOT_READINESS_MARKDOWN_PATH=evidence/greenhouse-pilot-readiness.md

# Scheduled autopilot safety
# Separate from the real-submit gate. The Celery beat schedule is inert while this remains false.
AUTOPILOT_ENABLED=false
AUTOPILOT_DEFAULT_DAILY_CAP=5
AUTOPILOT_DEFAULT_WEEKLY_CAP=20
# UTC quiet-hours window. Equal values disable quiet hours; wraparound windows are supported.
AUTOPILOT_QUIET_HOURS_START_UTC=0
AUTOPILOT_QUIET_HOURS_END_UTC=6
# Repeated operational failures pause scheduled application creation.
AUTOPILOT_FAILURE_THRESHOLD=3
AUTOPILOT_FAILURE_WINDOW_MINUTES=60
AUTOPILOT_CIRCUIT_BREAKER_MINUTES=120
# Comma-separated: greenhouse,lever,ashby,smartrecruiters,workday,generic or all.
AUTOPILOT_DISABLED_PLATFORMS=

# Resumable human handoffs
# Dry runs always retain CAPTCHA/login/MFA/navigation boundaries so they can be completed
# through JobTomatik. Set true to extend retained handoffs to supervised live runs.
ENABLE_RESUMABLE_HANDOFFS=false
# Local-CDP sessions require API and application workers to reach the same browser node.
JOBTOMATIK_BROWSER_NODE_ID=local-node
HANDOFF_STORAGE_DIR=handoff_sessions
# Certified defaults: 20-minute session, 5-minute interaction lease, 60-minute maximum session.

# Job Boards / integrations, optional
RAPIDAPI_KEY=

# Frontend
VITE_API_URL=http://127.0.0.1:8010
